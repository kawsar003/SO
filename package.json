  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=public_html/management/server.cjs && cp schema.sql public_html/management/ && cp database.json public_html/management/ 2>/dev/null || true && cp auth_settings.json public_html/management/ 2>/dev/null || true && cp telegram_settings.json public_html/management/ 2>/dev/null || true",
    "start": "node public_html/management/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf public_html/management server.cjs",
    "lint": "tsc --noEmit"
  },
